<?xml version="1.0"?>
<ruleset name="Customized Rules" xmlns="http://pmd.sourceforge.net/ruleset/2.0.0"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://pmd.sourceforge.net/ruleset/2.0.0 http://pmd.sourceforge.net/ruleset_2_0_0.xsd">
    
    <description>
        Customized PMD ruleset for Teedy project, including the following metrics:
        - Lines of code (LoC)
        - Cyclomatic Complexity (CC)
        - Weighted Methods per Class (WMC)
        - Coupling Between Objects (CBO)
        - Lack of Cohesion in Methods (LCOM)
    </description>
    
    <!-- Lines of code (LoC) -->
    <rule ref="category/java/design.xml/ExcessiveClassLength">
        <property name="maxLines" value="1500"/>
    </rule>
    <rule ref="category/java/design.xml/ExcessiveMethodLength">
        <property name="maxLines" value="200"/>
    </rule>
    
    <!-- Cyclomatic Complexity (CC) - increased thresholds to reduce false positives -->
    <rule ref="category/java/design.xml/CyclomaticComplexity">
        <property name="minimum" value="25"/>
    </rule>
    
    <!-- Weighted Methods per Class (WMC) -->
    <rule ref="category/java/design.xml/ExcessivePublicCount">
        <property name="max" value="50"/>
    </rule>
    
    <!-- Coupling Between Objects (CBO) -->
    <rule ref="category/java/design.xml/ExcessiveImports">
        <property name="maxImports" value="50"/>
    </rule>
    <rule ref="category/java/design.xml/TooManyFields">
        <property name="maxFields" value="50"/>
    </rule>
    
    <!-- Lack of Cohesion in Methods (LCOM) -->
    <rule ref="category/java/design.xml/TooManyMethods">
        <property name="maxMethods" value="50"/>
    </rule>
</ruleset>