<?xml version="1.0"?>
<ruleset name="Customized Rules" xmlns="http://pmd.sourceforge.net/ruleset/2.0.0"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://pmd.sourceforge.net/ruleset/2.0.0 http://pmd.sourceforge.net/ruleset_2_0_0.xsd">
    
    <description>
        Customized PMD ruleset for Teedy project, including the following metrics:
        - Lines of code (LoC)
        - Cyclomatic Complexity (CC)
        - Weighted Methods per Class (WMC)
        - Coupling Between Objects (CBO)
        - Lack of Cohesion in Methods (LCOM)
    </description>
    
    <!-- Lines of code (LoC) -->
    <rule ref="category/java/design.xml/ExcessiveClassLength" properties="maxLines=1500"/>
    <rule ref="category/java/design.xml/ExcessiveMethodLength" properties="maxLines=200"/>
    
    <!-- Cyclomatic Complexity (CC) - increased thresholds to reduce false positives -->
    <rule ref="category/java/design.xml/CyclomaticComplexity" properties="minimum=25"/>
    
    <!-- Weighted Methods per Class (WMC) -->
    <rule ref="category/java/design.xml/ExcessivePublicCount" properties="max=50"/>
    
    <!-- Coupling Between Objects (CBO) -->
    <rule ref="category/java/design.xml/ExcessiveImports" properties="maxImports=50"/>
    <rule ref="category/java/design.xml/TooManyFields" properties="maxFields=50"/>
    
    <!-- Lack of Cohesion in Methods (LCOM) -->
    <rule ref="category/java/design.xml/TooManyMethods" properties="maxMethods=50"/>
</ruleset>